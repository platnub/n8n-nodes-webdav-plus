{
  "name": "n8n-nodes-webdav-plus",
  "version": "1.0.0",
  "description": "N8N community node for CalDAV calendars and CardDAV contacts using tsdav",
  "keywords": [
    "n8n-community-node-package",
    "caldav",
    "carddav",
    "webdav",
    "calendar",
    "contacts",
    "addressbook",
    "ical",
    "vcard",
    "events",
    "google-calendar",
    "icloud",
    "fastmail",
    "nextcloud",
    "webdav-plus"
  ],
  "license": "MIT",
  "homepage": "https://github.com/platnub/n8n-nodes-webdav-plus",
  "author": {
    "name": "Platnub"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/platnub/n8n-nodes-webdav-plus.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials",
    "lintfix": "eslint nodes credentials --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/WebDavPlusApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/WebDavPlus/WebDavPlus.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "*",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "tsdav": "^2.1.8"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
